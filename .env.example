# Environment setup
ENVIRONMENT=development
LOG_LEVEL=info

# FastAPI
APP_NAME=Compliance Gate
APP_VERSION=0.1.0

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=compliance_gate
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Celery
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Application Secrets (Change in Production!)
# SECRET_KEY=your-super-secret-key-here

# Data Platform
CG_DATA_DIR=/workspace
CG_UPLOAD_DIR=/workspace/uploads
DEFAULT_TENANT_ID=default

# Auth Core
AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=45
AUTH_JWT_ISSUER=compliance-gate
AUTH_JWT_AUDIENCE=compliance-gate-api
AUTH_MFA_ISSUER=Compliance Gate
AUTH_RECOVERY_PEPPER=change-recovery-pepper
AUTH_SECRET_PROTECTION_KEY=change-secret-protection-key
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=Admin1234
